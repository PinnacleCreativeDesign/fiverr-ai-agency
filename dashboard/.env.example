# ============================================================================
# Dashboard env vars
# ============================================================================
# SERVICE_ROLE_KEY is read server-side only (via the /api/dashboard route).
# Never expose it to the browser. The two NEXT_PUBLIC_ vars are bundled into
# client JS and are safe to commit to e.g. preview environments.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Polling cadence (milliseconds) for the dashboard's /api/dashboard fetch.
NEXT_PUBLIC_POLL_INTERVAL_MS=2000
