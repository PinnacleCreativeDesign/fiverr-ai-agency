# ============================================================================
# Fiverr AI Agency — Environment Variables
# ============================================================================
# Copy this file to .env and fill in values. Never commit .env.
# Variable names match what each component (orchestrator, n8n, dashboard) reads.

# --- Supabase ---
# From Project Settings → API in the Supabase dashboard.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Server-side connection string (transaction pooler recommended for Python workers).
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- LLM APIs ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Image generation ---
FAL_KEY=
FAL_FLUX_PRO_ENDPOINT=fal-ai/flux-pro/v1.1
REPLICATE_API_TOKEN=

# --- Local SDXL via ComfyUI (RunPod or local) ---
COMFYUI_URL=http://localhost:8188

# --- Gmail intake ---
# Paths to OAuth files. See docs/intake-setup.md for bootstrap.
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
# Gmail label names. Nested labels use `/` as separator (Fiverr/Orders).
GMAIL_LABEL_PENDING=Fiverr/Orders
GMAIL_LABEL_PROCESSED=FiverrAgency/Processed
GMAIL_LABEL_FAILED=FiverrAgency/Failed
# Polling cadence + per-cycle batch size for `agency intake-loop`.
INTAKE_POLL_INTERVAL_SECONDS=60
INTAKE_MAX_PER_CYCLE=10

# --- n8n ---
N8N_WEBHOOK_INTAKE_URL=https://your-n8n.example.com/webhook/fiverr-intake
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# --- Storage ---
# Supabase Storage bucket names. Create these in the dashboard before first run.
STORAGE_BUCKET_REFERENCES=client-references
STORAGE_BUCKET_DELIVERABLES=deliverables
STORAGE_BUCKET_PACKAGES=delivery-packages

# --- Operations ---
LOG_LEVEL=info
BRIEF_CONFIDENCE_THRESHOLD=0.65
BRAND_CONSISTENCY_THRESHOLD=0.75
MAX_GENERATION_RETRIES=2

# --- Dashboard (Next.js) ---
# These are read by the dashboard. NEXT_PUBLIC_ vars are exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
